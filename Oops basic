class Employee
{
    int empno;
    String name;
    float sal;
    Employee(){
        empno=101;
        name="ahon";
        sal=5000f;
        
    }
    void displayDetails(){
        System.out.println(empno +" | "+ name +" | "+ sal);
    }
}

class Main {
    public static void main(String[] args) {
        Employee emp1=new Employee();
        emp1.displayDetails();
        
        
    }
   
}
